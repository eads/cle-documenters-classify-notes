# Google credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_IMPERSONATE_USER=user@example.com   # optional; requires domain-wide delegation

# Google Drive / Sheets
ROOT_DRIVE_FOLDER=<Drive folder ID>
CLASSIFIER_OUTPUT_SHEET=<Google Sheet ID>

# OpenAI
OPENAI_API_KEY=sk-...

# LangSmith tracing (https://smith.langchain.com)
# Create a project, generate an API key, paste here.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=cle-documenters

# Run tagging — traces appear with these labels in LangSmith.
# RUN_STAGE: "classification" (real run) or "testing" (local verification).
# LANGSMITH_ENV: environment name (e.g. "prod") — stub for future use.
# Both are optional; absent = no tags added. GH Actions sets RUN_STAGE=classification automatically.
RUN_STAGE=testing
# LANGSMITH_ENV=

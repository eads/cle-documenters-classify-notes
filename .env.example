# Google credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_IMPERSONATE_USER=user@example.com   # optional; requires domain-wide delegation

# Google Drive / Sheets
ROOT_DRIVE_FOLDER=<Drive folder ID>
CLASSIFIER_OUTPUT_SHEET=<Google Sheet ID>

# OpenAI
OPENAI_API_KEY=sk-...

# LangSmith tracing (https://smith.langchain.com)
# Create a project, generate an API key, paste here.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=cle-documenters
